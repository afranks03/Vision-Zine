# Vision Zine — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit real keys.

# --- Supabase ---
# Project URL and publishable (anon-equivalent) key from supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-only secret key (formerly service_role). Bypasses RLS — never expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Site ---
# The canonical URL for OG images, email links, etc.
# Local dev: http://localhost:3000
# Vercel preview: $VERCEL_URL is auto-populated; this is the production override.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic (Phase 2) ---
# Get from console.anthropic.com → Settings → API Keys → Create Key.
# Server-only — never expose to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe (Phase 4) ---
# dashboard.stripe.com → Developers → API keys (test mode)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# dashboard.stripe.com → Developers → Webhooks → endpoint signing secret
# For local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and use the whsec_ value it prints.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: pin pre-created Stripe Price IDs (otherwise we use inline price_data)
# STRIPE_PRICE_ONE_ISSUE=price_xxxxxxxxxxxxxx
# STRIPE_PRICE_ANNUAL=price_xxxxxxxxxxxxxx

# --- Resend (Phase 5b) ---
# resend.com → API Keys → Create. Free tier covers ~3k emails/month.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# The verified sending identity. For dev, leave as onboarding@resend.dev
# (Resend's shared sandbox sender). For production, verify your own domain
# at resend.com → Domains and use something like "Vision Zine <hello@visionzine.com>".
EMAIL_FROM=Vision Zine <onboarding@resend.dev>
# Optional: BCC every transactional email here so you have a paper trail
# while the product is young. Leave blank to disable.
EMAIL_BCC=

# --- Lulu xPress (Phase 4d) ---
# lulu.com → Developer Portal → Client Keys
LULU_CLIENT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LULU_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox while testing; switch to https://api.lulu.com for production.
LULU_API_BASE=https://api.sandbox.lulu.com
# Optional: override the pod_package_id used for every printed copy
# (otherwise lib/print/lulu.ts picks per-format defaults).
# LULU_POD_PACKAGE_OVERRIDE=0850X1100BWSTDPB060UW444MXX
